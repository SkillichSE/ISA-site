# Recommended — ask server owner for webhook URL:
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/ID/TOKEN

# Alternative — bot (needs channel permissions):
DISCORD_BOT_TOKEN=your_bot_token_here
LAUNCH_CHANNEL_ID=1514303404103700530

# Admin panel
# Real password for the admin panel. Never commit the actual value.
ADMIN_PASSWORD=change-me-to-a-strong-random-password
# Optional but recommended: separate secret used to sign admin session
# cookies. If omitted, ADMIN_PASSWORD is reused as the signing secret.
SESSION_SECRET=change-me-to-a-long-random-string

# Supabase — service-role key must stay server-side only (used by
# api/admin/data.js and api/admin/upload.js). Never put it in admin.html
# or any other client-side file.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
